[Unit]
Description=NetMon WiFi Station Monitor
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/usr/bin/python3 /opt/netmon/scripts/wifi_station.py
EnvironmentFile=/opt/netmon/config/secrets.env
Restart=always
RestartSec=10
StartLimitIntervalSec=300
StartLimitBurst=10
StandardOutput=journal
StandardError=journal
SyslogIdentifier=netmon-wifi-station

[Install]
WantedBy=multi-user.target
